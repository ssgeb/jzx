# -------------------- 数据库 --------------------
DB_URL=jdbc:mysql://host.docker.internal:3306/doorhandledb?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useUnicode=true&characterEncoding=utf8mb4
DB_USERNAME=root
DB_PASSWORD=replace-with-database-password

# -------------------- Redis --------------------
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-redis-password

# -------------------- Kafka --------------------
APP_KAFKA_ENABLED=true
APP_KAFKA_BOOTSTRAP_SERVERS=host.docker.internal:9092

# -------------------- 外部记忆服务 --------------------
MEM0_SERVICE_URL=http://host.docker.internal:8081
MEM0_ENABLED=true

# -------------------- Python Harness Agent --------------------
CHAT_ASSISTANT_ENGINE=python
CHAT_ASSISTANT_FALLBACK_TO_JAVA=true
PYTHON_ASSISTANT_URL=http://python-assistant:8090
PYTHON_ASSISTANT_CONNECT_TIMEOUT_MS=2000
PYTHON_ASSISTANT_READ_TIMEOUT_MS=300000
ASSISTANT_REQUIRE_SIGNATURE=true
ASSISTANT_HMAC_SECRET=replace-with-at-least-32-random-characters
ASSISTANT_REPLAY_REDIS_URL=redis://:replace-with-redis-password@host.docker.internal:6379/0
ASSISTANT_DEEP_AGENT_ENABLED=true
ASSISTANT_DEEP_AGENT_MODEL=deepseek-chat
ASSISTANT_DEEP_AGENT_MAX_ITERATIONS=40
ASSISTANT_DEEP_AGENT_MODEL_TIMEOUT_SECONDS=60
ASSISTANT_DEEP_AGENT_MODEL_MAX_RETRIES=1
ASSISTANT_SUBAGENT_CONFIG_PATH=python_assistant_service/config/subagents.yaml

# -------------------- Skill 安全下载 --------------------
# 只下载到隔离区，不会自动加载或执行。仓库列表使用英文逗号分隔。
ASSISTANT_SKILLS_ENABLED=true
ASSISTANT_SKILL_ALLOWED_REPOSITORIES=openai/skills
ASSISTANT_SKILL_MAX_DOWNLOAD_BYTES=10485760
ASSISTANT_SKILL_MAX_FILES=200
ASSISTANT_SKILL_MAX_FILE_BYTES=2097152
ASSISTANT_SKILL_MAX_EXTRACTED_BYTES=20971520

# -------------------- 身份认证 --------------------
JWT_SECRET=replace-with-at-least-32-random-characters

# -------------------- 大语言模型 --------------------
DEEPSEEK_ENABLED=true
DEEPSEEK_API_KEY=replace-with-deepseek-api-key

# -------------------- 阿里云 OSS --------------------
ALIYUN_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_BUCKET=replace-with-oss-bucket
ALIYUN_OSS_ACCESS_KEY_ID=replace-with-oss-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=replace-with-oss-access-key-secret

# -------------------- JVM --------------------
JAVA_OPTS=-Xms512m -Xmx1024m
