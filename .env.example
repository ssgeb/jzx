# ============================================================
# DoorHandleCatch 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================================

# -------------------- 数据库 --------------------
DB_URL="jdbc:mysql://localhost:3306/doorhandledb?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useUnicode=true&characterEncoding=UTF-8&rewriteBatchedStatements=true"
DB_USERNAME=root
DB_PASSWORD=your_db_password

# -------------------- JWT --------------------
JWT_SECRET=your_jwt_secret_key_at_least_256_bits
JWT_EXPIRATION=604800

# -------------------- 阿里云 OSS (Java / Python 共用) --------------------
ALIYUN_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_BUCKET=handlecatchs
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret

# -------------------- Kafka --------------------
# Java 端
APP_KAFKA_ENABLED=true
APP_KAFKA_BOOTSTRAP_SERVERS=10.20.144.118:9092
APP_KAFKA_CONSUMER_GROUP=doorhandlecatch-detection
APP_KAFKA_TOPIC_TASK_CREATED=detection.task.created
APP_KAFKA_TOPIC_TASK_FINISHED=detection.task.finished
APP_KAFKA_TOPIC_TASK_PROGRESS=detection.task.progress
# Python 端 (独立 worker 使用)
KAFKA_BOOTSTRAP_SERVERS=10.20.144.118:9092
KAFKA_TASK_CREATED_TOPIC=detection.task.created
KAFKA_TASK_FINISHED_TOPIC=detection.task.finished
KAFKA_CONSUMER_GROUP=doorhandlecatch-python
KAFKA_DELIVERY_TIMEOUT_SECONDS=10

# -------------------- Detection Worker --------------------
APP_DETECTION_WORKER_ENABLED=true
APP_DETECTION_WORKER_DEPLOYMENT=remote
APP_DETECTION_WORKER_LABEL=remote-python-worker

# -------------------- 文件上传路径 --------------------
UPLOAD_ROOT_DIR=./uploads
MODEL_UPLOAD_DIR=./uploads/models
DETECTION_UPLOAD_DIR=./uploads/images
DETECTION_RESULT_DIR=./uploads/results
DETECTION_ANNOTATED_DIR=./uploads/annotated
DEFAULT_MODEL_FILE=2f051822-fa0e-4803-9561-ede47fe3b362.onnx

# -------------------- Chat Assistant --------------------
CHAT_ASSISTANT_ENABLED=true
CHAT_ASSISTANT_DEFAULT_SESSION_SUFFIX=default
CHAT_ASSISTANT_MAX_HISTORY_MESSAGES=30
CHAT_ASSISTANT_VOICE_TRANSCRIBE_URL=http://127.0.0.1:9001/transcribe
CHAT_ASSISTANT_VOICE_TRANSCRIBE_ALLOWED_HOSTS=localhost,127.0.0.1,::1
CHAT_ASSISTANT_VOICE_CONNECT_TIMEOUT_MS=1500
CHAT_ASSISTANT_VOICE_READ_TIMEOUT_MS=30000
CHAT_ASSISTANT_VOICE_MAX_BYTES=10485760

# Python 智能体服务（浏览器不能直接访问该地址）
CHAT_ASSISTANT_ENGINE=java
CHAT_ASSISTANT_FALLBACK_TO_JAVA=true
PYTHON_ASSISTANT_URL=http://127.0.0.1:8090
PYTHON_ASSISTANT_CONNECT_TIMEOUT_MS=2000
PYTHON_ASSISTANT_READ_TIMEOUT_MS=300000
ASSISTANT_REQUIRE_SIGNATURE=true
ASSISTANT_HMAC_SECRET=replace_with_at_least_32_random_characters
ASSISTANT_SIGNATURE_MAX_SKEW_SECONDS=60
ASSISTANT_REPLAY_REDIS_URL=redis://127.0.0.1:6379/0
JAVA_AGENT_TOOL_BASE_URL=http://127.0.0.1:8080
JAVA_AGENT_TOOL_TIMEOUT_SECONDS=15
ASSISTANT_HOST=127.0.0.1
ASSISTANT_PORT=8090
ASSISTANT_DEEP_AGENT_ENABLED=true
ASSISTANT_DEEP_AGENT_MODEL=deepseek-chat
ASSISTANT_DEEP_AGENT_MAX_ITERATIONS=40
ASSISTANT_DEEP_AGENT_MODEL_TIMEOUT_SECONDS=60
ASSISTANT_DEEP_AGENT_MODEL_MAX_RETRIES=1
ASSISTANT_SUBAGENT_CONFIG_PATH=python_assistant_service/config/subagents
ASSISTANT_RAG_ENABLED=true
ASSISTANT_RAG_SOURCES=legacy-service/src/main/resources/rag/system-user-guide.md,legacy-service/src/main/resources/rag/assistant-rag-guide.md,README.md
ASSISTANT_RAG_CHUNK_SIZE=900
ASSISTANT_RAG_TOP_K=4
ASSISTANT_RAG_MAX_CONTEXT_CHARS=2600
ASSISTANT_MEMORY_ENABLED=true
ASSISTANT_MEMORY_TOP_K=5
MEM0_SERVICE_URL=http://127.0.0.1:8081
MEM0_CONNECT_TIMEOUT_MS=2000
MEM0_READ_TIMEOUT_MS=5000
ASSISTANT_SKILLS_ENABLED=true
ASSISTANT_SKILLS_ROOT=runtime/assistant-skills
ASSISTANT_SKILL_ALLOWED_REPOSITORIES=openai/skills
ASSISTANT_SKILL_MAX_DOWNLOAD_BYTES=10485760
ASSISTANT_SKILL_MAX_FILES=200
ASSISTANT_SKILL_MAX_FILE_BYTES=2097152
ASSISTANT_SKILL_MAX_EXTRACTED_BYTES=20971520

# -------------------- Local ASR (faster-whisper) --------------------
ASR_MODEL=base
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
ASR_MAX_UPLOAD_BYTES=10485760

# -------------------- DeepSeek LLM (多Agent智能路由) --------------------
DEEPSEEK_ENABLED=true
DEEPSEEK_API_KEY=sk-your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# -------------------- Memory Service Embedding --------------------
EMBEDDING_API_KEY=sk-your_embedding_api_key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# -------------------- MyBatis 日志 --------------------
MYBATIS_LOG_IMPL=org.apache.ibatis.logging.slf4j.Slf4jImpl

# -------------------- 日志（默认仅控制台） --------------------
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=INFO
LOG_LEVEL_WEB=INFO
LOG_LEVEL_JDBC=INFO
